#!/bin/bash

# ==========================================
# AUTO INSTALLER MASTER PANEL - HOKAGE LEGEND
# ==========================================

# Definisi Warna
CYAN='\033[96m'
GREEN='\033[92m'
YELLOW='\033[93m'
RED='\033[91m'
RESET='\033[0m'
BOLD='\033[1m'

clear
echo -e "${CYAN}${BOLD}╔═════════════════════════════════════════════════════════════════╗${RESET}"
echo -e "${CYAN}${BOLD}║           HOKAGE LEGEND MASTER PANEL AUTO INSTALLER             ║${RESET}"
echo -e "${CYAN}${BOLD}╚═════════════════════════════════════════════════════════════════╝${RESET}"
echo ""

# 1. Validasi Root
if [ "${EUID}" -ne 0 ]; then
    echo -e "${RED}[!] Harap jalankan script ini sebagai root (sudo su).${RESET}"
    exit 1
fi

# 2. Instalasi Dependensi Wajib Master Panel
echo -e "${YELLOW}[*] Memasang dependensi sistem (Python3, SSHPass, Git, Unzip)...${RESET}"
apt-get update -y > /dev/null 2>&1
apt-get install -y python3 python3-pip sqlite3 sshpass wget curl git unzip tar > /dev/null 2>&1

# 3. Pembuatan Struktur Direktori Utama
echo -e "${YELLOW}[*] Menyiapkan struktur direktori di /usr/local/sbin/...${RESET}"
MASTER_DIR="/usr/local/sbin/master-admin"

# Membersihkan instalasi lama jika ada
rm -rf $MASTER_DIR
mkdir -p $MASTER_DIR
mkdir -p $MASTER_DIR/config
mkdir -p $MASTER_DIR/logs

# 4. Mengunduh Repositori GitHub Utama
echo -e "${YELLOW}[*] Mengunduh data dari GitHub (master-admin & alphaV1)...${RESET}"
cd /tmp

# Mengunduh dan mengekstrak repositori master-admin
wget -q -O master-admin.zip "https://github.com/hokagelegend/master-admin/archive/refs/heads/main.zip"
unzip -q master-admin.zip
cp -r master-admin-main/* $MASTER_DIR/

# Mengunduh dan mengekstrak repositori alphaV1 (Gudang Installer Lokal)
wget -q -O alphaV1.zip "https://github.com/hokagelegend/alphaV1/archive/refs/heads/main.zip"
unzip -q alphaV1.zip
mkdir -p $MASTER_DIR/alphaV1
cp -r alphaV1-main/* $MASTER_DIR/alphaV1/

# Membersihkan file sementara
rm -rf /tmp/master-admin* /tmp/alphaV1*

# 5. Konfigurasi Kredensial Interaktif
echo -e "\n${CYAN}=== SETUP KREDENSIAL MASTER ===${RESET}"
echo -e "Untuk fitur Auto-License GitHub, masukkan Personal Access Token Anda."
echo -e "Kosongkan dan tekan Enter jika Anda ingin mengaturnya manual nanti."
read -p "❯ Masukkan GitHub Token (ghp_xxx) : " gh_token

if [ -z "$gh_token" ]; then
    gh_token="ghp_KOSONG_SILAKAN_ISI_MANUAL"
    echo -e "${YELLOW}[!] Token dikosongkan. Harap edit secara manual nanti.${RESET}"
fi

# Membuat file credentials.py yang aman
cat > $MASTER_DIR/config/credentials.py <<EOF
# ==========================================
# FILE SENSITIF - KREDENSIAL MASTER PANEL
# ==========================================

# Konfigurasi GitHub API (Auto-License)
GITHUB_TOKEN = "${gh_token}"
GITHUB_REPO = "hokagelegend9999/ijin"
GITHUB_PATH = "alpha"
EOF

# Kunci file agar hanya root yang bisa membaca
chmod 600 $MASTER_DIR/config/credentials.py

# 6. Pengaturan Perizinan & Shortcut (Symlink)
echo -e "\n${YELLOW}[*] Mengatur perizinan dan shortcut terminal...${RESET}"
chmod +x $MASTER_DIR/core_admin.py
chmod +x $MASTER_DIR/install_vps 2>/dev/null

# Membuat perintah "admin" bisa dipanggil dari mana saja
ln -sf $MASTER_DIR/core_admin.py /usr/local/sbin/admin
chmod +x /usr/local/sbin/admin

echo -e "\n${GREEN}${BOLD}[✓] INSTALASI MASTER PANEL SELESAI!${RESET}"
echo -e "Ketik perintah di bawah ini untuk membuka panel Anda:"
echo -e "${CYAN}${BOLD}admin${RESET}\n"
